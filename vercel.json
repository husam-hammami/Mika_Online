{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "BASE_PATH=/ PORT=3000 pnpm --filter @workspace/mika-site run build",
  "outputDirectory": "artifacts/mika-site/dist/public",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
